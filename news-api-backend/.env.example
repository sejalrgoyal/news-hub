# News API - https://newsapi.org/
NEWS_API_KEY=your_news_api_key

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Server
PORT=3001

# CORS - set to your frontend URL in production (e.g. https://your-app.netlify.app)
# Leave as * to allow all origins in development
CORS_ORIGIN=*
